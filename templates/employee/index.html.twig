<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Pair Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .upload-card {
            border: 2px dashed #dee2e6;
            border-radius: 12px;
            transition: border-color 0.2s ease;
            cursor: pointer;
        }

        .upload-card:hover,
        .upload-card.drag-over {
            border-color: #0d6efd;
            background-color: #f0f5ff;
        }

        .upload-card .bi-cloud-upload {
            font-size: 3rem;
            color: #adb5bd;
        }

        .result-banner {
            background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);
            border-radius: 12px;
            color: #fff;
        }

        .result-banner .display-emp {
            font-size: 2.5rem;
            font-weight: 700;
        }

        .result-banner .total-days {
            font-size: 1.1rem;
            opacity: 0.85;
        }

        .table thead th {
            background-color: #e9ecef;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .badge-days {
            font-size: 0.9rem;
            padding: 0.4em 0.75em;
        }
    </style>
</head>
<body>

<div class="container py-5" style="max-width: 860px;">

    {# ── Page header ── #}
    <div class="mb-4">
        <h1 class="h3 fw-bold mb-1">
            <i class="bi bi-people-fill text-primary me-2"></i>Employee Pair Finder
        </h1>
        <p class="text-muted mb-0">
            Upload a CSV export to find the two employees who worked together the longest.
        </p>
    </div>

    {# ── Error alert ── #}
    {% if errorMessage %}
        <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
            <span>{{ errorMessage }}</span>
        </div>
    {% endif %}

    {# ── Upload form ── #}
    {{ form_start(form, {attr: {enctype: 'multipart/form-data', id: 'upload-form'}}) }}
    <div class="card shadow-sm mb-4">
        <div class="card-body p-4">

            <div class="upload-card text-center p-4 mb-3" id="drop-zone">
                <i class="bi bi-cloud-upload d-block mb-2"></i>
                <p class="mb-1 fw-semibold">Drag &amp; drop your CSV here</p>
                <p class="text-muted small mb-3">or click the button below to browse</p>

                {{
                    form_widget(form.csvFile, {
                        attr: { class: 'd-none' }
                    })
                }}

                <label for="{{ form.csvFile.vars.id }}" class="btn btn-outline-primary btn-sm" style="cursor:pointer;">
                    <i class="bi bi-folder2-open me-1"></i>Browse file
                </label>

                <p class="text-muted small mt-2 mb-0" id="file-name-label">No file selected</p>
            </div>

            {% if form.csvFile.vars.errors|length %}
                <div class="text-danger small mt-1">
                    {% for error in form.csvFile.vars.errors %}
                        <div>{{ error.message }}</div>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="text-end">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-search me-1"></i>Analyse
                </button>
            </div>
        </div>
    </div>
    {{ form_end(form) }}

    {# ── Results ── #}
    {% if result %}

        {# Winner banner #}
        <div class="result-banner p-4 mb-4 shadow-sm">
            <div class="row align-items-center">
                <div class="col-auto">
                    <i class="bi bi-trophy-fill" style="font-size:2.5rem; opacity:0.8;"></i>
                </div>
                <div class="col">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <span class="display-emp">{{ result.employeeIdOne }}</span>
                        <i class="bi bi-arrows-collapse" style="font-size:1.5rem; opacity:0.6;"></i>
                        <span class="display-emp">{{ result.employeeIdTwo }}</span>
                    </div>
                    <div class="total-days mt-1">
                        Worked together for
                        <strong>{{ result.totalDaysTogether }} day{{ result.totalDaysTogether != 1 ? 's' }}</strong>
                        across {{ result.projects|length }} project{{ result.projects|length != 1 ? 's' }}
                    </div>
                </div>
            </div>
        </div>

        {# Per-project datagrid #}
        <div class="card shadow-sm">
            <div class="card-header py-3">
                <h2 class="h6 fw-bold mb-0">
                    <i class="bi bi-table me-1 text-muted"></i>Common Projects Breakdown
                </h2>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Employee #1</th>
                            <th>Employee #2</th>
                            <th>Project ID</th>
                            <th class="text-end">Days worked together</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for project in result.projects %}
                            <tr>
                                <td>
                                    <span class="badge bg-primary bg-opacity-10 text-primary fw-semibold px-3 py-2">
                                        {{ project.employeeIdOne }}
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-purple bg-opacity-10 text-purple fw-semibold px-3 py-2"
                                          style="background-color:#f3effe; color:#6610f2;">
                                        {{ project.employeeIdTwo }}
                                    </span>
                                </td>
                                <td class="text-muted">{{ project.projectId }}</td>
                                <td class="text-end">
                                    <span class="badge bg-success badge-days">
                                        {{ project.daysWorkedTogether }}d
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="fw-semibold text-end text-muted">Total</td>
                            <td class="text-end">
                                <span class="badge bg-dark badge-days">{{ result.totalDaysTogether }}d</span>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

    {% endif %}

    {# ── Expected format hint ── #}
    <div class="card mt-4 border-0 bg-light">
        <div class="card-body py-3 px-4">
            <p class="small text-muted mb-1 fw-semibold">Expected CSV format</p>
            <code class="small text-secondary">EmpID, ProjectID, DateFrom, DateTo</code>
            <p class="small text-muted mt-2 mb-0">
                <strong>DateTo</strong> can be <code>NULL</code> (treated as today).
                Supported date formats: <em>YYYY-MM-DD, DD/MM/YYYY, DD.MM.YYYY,
                MM/DD/YYYY, YYYYMMDD, Unix timestamp, "January 5, 2014"</em>.
            </p>
        </div>
    </div>

</div>

<script>
    // Show selected file name
    const input    = document.getElementById('{{ form.csvFile.vars.id }}');
    const label    = document.getElementById('file-name-label');
    const dropZone = document.getElementById('drop-zone');

    input.addEventListener('change', () => {
        label.textContent = input.files.length ? input.files[0].name : 'No file selected';
    });

    // Drag-and-drop wiring
    dropZone.addEventListener('dragover', e => {
        e.preventDefault();
        dropZone.classList.add('drag-over');
    });

    ['dragleave', 'dragend'].forEach(evt =>
        dropZone.addEventListener(evt, () => dropZone.classList.remove('drag-over'))
    );

    dropZone.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('drag-over');

        const files = e.dataTransfer.files;
        if (files.length) {
            // Assign to the hidden file input, then auto-submit
            const dt = new DataTransfer();
            dt.items.add(files[0]);
            input.files = dt.files;
            label.textContent = files[0].name;
            document.getElementById('upload-form').submit();
        }
    });
</script>

</body>
</html>
